  "license": "MIT",
  "scripts": {
    "start": "node apps/api/dist/main.js",
    "api": "nx serve api",
    "api:build": "nx build api",
    "admin": "nx dev admin",
    "admin:build": "nx build admin",
    "admin:preview": "nx preview admin",
    "customer": "nx dev customer",
    "customer:build": "nx build customer",
    "dev": "nx run-many -t serve dev --projects=api,admin,customer",
    "storybook": "nx storybook ui",
    "storybook:build": "nx build-storybook ui",
    "ui:build": "nx build ui",
    "ui:typecheck": "nx typecheck ui",
    "build": "nx run-many -t build",
    "typecheck": "nx run-many -t typecheck",
    "graph": "nx graph",
    "migration:run": "TS_NODE_PROJECT=apps/api/tsconfig.app.json TS_NODE_TRANSPILE_ONLY=1 typeorm-ts-node-commonjs migration:run -d apps/api/src/database/data-source.ts",
    "migration:revert": "TS_NODE_PROJECT=apps/api/tsconfig.app.json TS_NODE_TRANSPILE_ONLY=1 typeorm-ts-node-commonjs migration:revert -d apps/api/src/database/data-source.ts",
    "migration:show": "TS_NODE_PROJECT=apps/api/tsconfig.app.json TS_NODE_TRANSPILE_ONLY=1 typeorm-ts-node-commonjs migration:show -d apps/api/src/database/data-source.ts",
    "migration:generate": "TS_NODE_PROJECT=apps/api/tsconfig.app.json TS_NODE_TRANSPILE_ONLY=1 typeorm-ts-node-commonjs migration:generate -d apps/api/src/database/data-source.ts",
    "seed:menu": "TS_NODE_PROJECT=apps/api/tsconfig.app.json TS_NODE_TRANSPILE_ONLY=1 TS_NODE_COMPILER_OPTIONS='{\"module\":\"node16\",\"moduleResolution\":\"node16\"}' ts-node apps/api/src/database/seeds/seed-menu.ts",
    "seed:categories": "TS_NODE_PROJECT=apps/api/tsconfig.app.json TS_NODE_TRANSPILE_ONLY=1 TS_NODE_COMPILER_OPTIONS='{\"module\":\"node16\",\"moduleResolution\":\"node16\"}' ts-node apps/api/src/database/seeds/seed-categories.ts"
  },
  "private": true,
