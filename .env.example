# eMenu API environment — copy to `.env` and adjust.

# Postgres connection (discrete vars). DB_HOST may be a TCP host or a unix
# socket directory (e.g. /var/run/postgresql) for local peer auth.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=emenu

# Or a single connection string (takes precedence over the DB_* vars above):
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/emenu

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
