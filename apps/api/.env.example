# eMenu API environment (copy to apps/api/.env for local dev)

# HTTP port
PORT=3000

# JWT signing secret — CHANGE THIS in any non-local environment
JWT_SECRET=dev-insecure-secret

# Token lifetime (zeit/ms format, e.g. 60s, 15m, 7d)
JWT_EXPIRES_IN=7d

# SQLite database file. Defaults to apps/api/emenu.sqlite when unset.
DATABASE_PATH=apps/api/emenu.sqlite
